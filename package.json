    "desktop:build:debug": "npm --workspace desktop run desktop:build:debug"
  },
  "devDependencies": {
    "turbo": "^2.5.4"
  },
  "workspaces": [
    "apps/*"
  ],
  "engines": {
    "node": ">=20"
  }
}