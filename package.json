{
  "name": "TuringFin",
  "version": "0.0.0",
  "private": true,
  "packageManager": "npm@11.6.1",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "desktop:dev": "npm --workspace desktop run desktop:dev",
