.page {
  padding: 24rpx;
}

.card {
  background: #fff;
  border-radius: 16rpx;
  padding: 28rpx;
  margin-bottom: 20rpx;
}

.h1 {
  display: block;
  font-size: 32rpx;
  font-weight: 600;
  margin-bottom: 16rpx;
}

.h2 {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  margin-bottom: 12rpx;
}

.p {
  display: block;
  font-size: 26rpx;
  color: #334155;
  line-height: 1.55;
  margin-bottom: 12rpx;
}

.p.small-gap {
  margin-top: 8rpx;
  margin-bottom: 0;
  font-size: 24rpx;
  color: #64748b;
}

.mono-wrap {
  margin-top: 8rpx;
  padding: 16rpx;
  background: #f8fafc;
  border: 1rpx solid #e2e8f0;
  border-radius: 10rpx;
}

.mono {
  display: block;
  font-size: 24rpx;
  color: #0f172a;
  word-break: break-all;
  font-family: ui-monospace, monospace;
}

.ghost {
  background: #f1f5f9;
  color: #0f172a;
  border-radius: 12rpx;
  font-size: 28rpx;
}
