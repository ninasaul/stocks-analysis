.page {
  padding: 24rpx;
  padding-bottom: 48rpx;
}

.card {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(15, 23, 42, 0.06);
}

.rep-card {
  border-left: 10rpx solid #cbd5e1;
  padding-left: 22rpx;
}

.rep-card.rep-wait {
  border-left-color: #94a3b8;
}

.rep-card.rep-trial {
  border-left-color: #2563eb;
}

.rep-card.rep-add {
  border-left-color: #059669;
}

.rep-card.rep-reduce {
  border-left-color: #d97706;
}

.rep-card.rep-exit {
  border-left-color: #dc2626;
}

.h1 {
  display: block;
  font-size: 32rpx;
  font-weight: 600;
}

.badge-wrap {
  margin-top: 12rpx;
}

.h2 {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  margin-bottom: 12rpx;
}

.h2.small-gap {
  margin-top: 20rpx;
}

.sub {
  display: block;
  margin-top: 12rpx;
  font-size: 24rpx;
  color: #64748b;
  line-height: 1.5;
}

.line {
  display: block;
  font-size: 26rpx;
  line-height: 1.5;
  margin-top: 6rpx;
}

.empty-wrap {
  padding: 48rpx 24rpx;
  text-align: center;
}

.empty {
  display: block;
  color: #94a3b8;
  font-size: 28rpx;
  margin-bottom: 24rpx;
}

.footer {
  padding: 24rpx 0 8rpx;
}

.foot-safe {
  padding-bottom: calc(8rpx + constant(safe-area-inset-bottom));
  padding-bottom: calc(8rpx + env(safe-area-inset-bottom));
}

.footer-btn {
  width: 100%;
  border-radius: 12rpx;
  font-size: 28rpx;
  background: #f1f5f9;
  color: #0f172a;
}

.footer-btn.primary {
  background: #0f172a;
  color: #fff;
}

.foot-gap {
  margin-top: 16rpx;
}

.empty-gap {
  margin-top: 20rpx;
}
