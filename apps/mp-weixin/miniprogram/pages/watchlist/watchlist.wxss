.page {
  padding: 24rpx;
  padding-bottom: 48rpx;
}

.card {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(15, 23, 42, 0.06);
}

.h1 {
  display: block;
  font-size: 32rpx;
  font-weight: 600;
  margin-bottom: 8rpx;
}

.desc {
  font-size: 24rpx;
  color: #64748b;
  line-height: 1.5;
}

.row {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 12rpx;
}

.add-bar {
  align-items: stretch;
}

.add-btn {
  background: #0f172a !important;
  color: #fff !important;
  border-radius: 10rpx !important;
  font-weight: 500;
  align-self: center;
}

.hint-line {
  display: block;
  font-size: 22rpx;
  color: #94a3b8;
  margin: -8rpx 0 16rpx 8rpx;
  line-height: 1.4;
}

.input {
  flex: 1;
  border: 1rpx solid #e2e8f0;
  border-radius: 12rpx;
  padding: 14rpx 16rpx;
  font-size: 28rpx;
}

.err {
  color: #b91c1c;
  font-size: 24rpx;
  margin-bottom: 12rpx;
}

.empty {
  text-align: center;
  padding: 48rpx 24rpx 32rpx;
}

.empty-t {
  display: block;
  font-size: 28rpx;
  color: #64748b;
  margin-bottom: 12rpx;
}

.empty-sub {
  display: block;
  font-size: 24rpx;
  color: #94a3b8;
  line-height: 1.5;
  margin-bottom: 24rpx;
}

.empty-btn {
  background: #0f172a;
  color: #fff;
  border-radius: 12rpx;
  font-size: 28rpx;
}

.row-card {
  display: flex;
  flex-direction: row;
  align-items: center;
  background: #fff;
  border-radius: 16rpx;
  padding: 20rpx;
  margin-bottom: 16rpx;
  gap: 12rpx;
  box-shadow: 0 4rpx 20rpx rgba(15, 23, 42, 0.06);
}

.grow {
  flex: 1;
  min-width: 0;
}

.title {
  display: block;
  font-size: 28rpx;
  font-weight: 500;
}

.title.up {
  color: #dc2626;
}

.title.down {
  color: #059669;
}

.title.flat {
  color: #64748b;
}

.sub {
  display: block;
  font-size: 24rpx;
  color: #64748b;
  margin-top: 6rpx;
}
