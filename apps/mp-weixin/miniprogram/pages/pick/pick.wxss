.page {
  min-height: 100vh;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  background: #f3f4f6;
  padding: 20rpx 20rpx calc(24rpx + env(safe-area-inset-bottom));
  gap: 14rpx;
}

.hero {
  background: linear-gradient(140deg, #0f172a 0%, #1d2939 100%);
  border-radius: 18rpx;
  padding: 20rpx;
  color: #f8fafc;
}

.hero-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 16rpx;
}

.hero-title {
  display: block;
  font-size: 34rpx;
  font-weight: 600;
}

.hero-sub {
  display: block;
  margin-top: 4rpx;
  font-size: 22rpx;
  color: #cbd5e1;
}

.hero-reset {
  margin: 0;
  min-height: 52rpx;
  line-height: 52rpx;
  padding: 0 18rpx;
  border-radius: 999rpx;
  font-size: 21rpx;
  color: #e2e8f0;
  background: rgba(255, 255, 255, 0.1);
  border: 1rpx solid rgba(255, 255, 255, 0.2);
}

.hero-reset::after {
  border: none;
}

.phase-row {
  margin-top: 18rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.phase-title {
  font-size: 26rpx;
  font-weight: 500;
}

.phase-progress {
  font-size: 22rpx;
  color: #cbd5e1;
}

.progress-track {
  margin-top: 10rpx;
  height: 10rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.2);
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  border-radius: 999rpx;
  background: linear-gradient(90deg, #22d3ee, #38bdf8);
}

.phase-hint {
  display: block;
  margin-top: 10rpx;
  font-size: 22rpx;
  color: #cbd5e1;
  line-height: 1.4;
}

.snapshot {
  background: #fff;
  border-radius: 16rpx;
  border: 1rpx solid #e5e7eb;
  padding: 8rpx 20rpx;
}

.snap-row {
  min-height: 70rpx;
  display: flex;
  align-items: center;
  gap: 10rpx;
  border-bottom: 1rpx solid #f1f5f9;
}

.snap-row:last-child {
  border-bottom: none;
}

.snap-key {
  width: 68rpx;
  font-size: 22rpx;
  color: #64748b;
}

.snap-val {
  flex: 1;
  min-width: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  font-size: 23rpx;
  color: #0f172a;
}

.snap-val-wide {
  max-width: calc(100% - 86rpx);
}

.candidate-card {
  background: #fff;
  border-radius: 16rpx;
  border: 1rpx solid #e5e7eb;
  padding: 18rpx 20rpx;
}

.candidate-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 8rpx;
}

.candidate-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #0f172a;
}

.candidate-count {
  font-size: 22rpx;
  color: #64748b;
}

.candidate-item {
  padding: 14rpx 0;
  border-top: 1rpx solid #f1f5f9;
}

.candidate-main {
  display: flex;
  align-items: baseline;
  gap: 10rpx;
}

.candidate-name {
  font-size: 27rpx;
  font-weight: 500;
  color: #0f172a;
}

.candidate-code {
  font-size: 22rpx;
  color: #64748b;
  font-family: "SF Mono", Menlo, Consolas, monospace;
}

.candidate-reason {
  display: block;
  margin-top: 8rpx;
  font-size: 23rpx;
  color: #475569;
  line-height: 1.45;
}

.candidate-btn {
  margin: 10rpx 0 0;
  min-height: 56rpx;
  line-height: 56rpx;
  border-radius: 10rpx;
  font-size: 22rpx;
  color: #1d4ed8;
  background: #eff6ff;
  border: 1rpx solid #bfdbfe;
}

.thread-wrap {
  flex: 1;
  min-height: 240rpx;
  background: #fff;
  border-radius: 16rpx;
  border: 1rpx solid #e5e7eb;
  overflow: hidden;
}

.thread {
  height: 100%;
  box-sizing: border-box;
  padding: 18rpx;
}

.msg {
  margin-bottom: 14rpx;
  padding: 14rpx 18rpx;
  border-radius: 12rpx;
  max-width: 92%;
}

.msg.user {
  margin-left: auto;
  background: #dbeafe;
  border: 1rpx solid #bfdbfe;
}

.msg.assistant {
  margin-right: auto;
  background: #f8fafc;
  border: 1rpx solid #e2e8f0;
}

.msg-text {
  font-size: 24rpx;
  line-height: 1.5;
  color: #1e293b;
  white-space: pre-wrap;
}

.actions {
  background: #fff;
  border-radius: 16rpx;
  border: 1rpx solid #e5e7eb;
  padding: 14rpx;
}

.action-primary {
  width: 100%;
  margin: 0;
  min-height: 82rpx;
  line-height: 82rpx;
  border-radius: 12rpx;
  font-size: 28rpx;
  font-weight: 500;
  color: #fff;
  background: #0f172a;
}

.action-primary::after {
  border: none;
}

.action-chips {
  margin-top: 10rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}

.action-chip {
  margin: 0;
  min-height: 56rpx;
  line-height: 56rpx;
  border-radius: 999rpx;
  padding: 0 18rpx;
  font-size: 22rpx;
  color: #334155;
  background: #f1f5f9;
  border: 1rpx solid #e2e8f0;
}

.action-chip::after {
  border: none;
}

.composer {
  display: flex;
  align-items: center;
  gap: 10rpx;
  background: #fff;
  border-radius: 16rpx;
  border: 1rpx solid #e5e7eb;
  padding: 10rpx;
}

.draft {
  flex: 1;
  min-height: 68rpx;
  border: 1rpx solid #e2e8f0;
  border-radius: 10rpx;
  padding: 0 16rpx;
  font-size: 25rpx;
  background: #f8fafc;
}

.send-btn {
  margin: 0;
  min-width: 106rpx;
  min-height: 68rpx;
  line-height: 68rpx;
  border-radius: 10rpx;
  font-size: 24rpx;
  color: #fff;
  background: #1d4ed8;
}

.send-btn::after {
  border: none;
}

.compliance {
  text-align: center;
  padding: 2rpx 8rpx 0;
  font-size: 20rpx;
  color: #94a3b8;
  line-height: 1.4;
}
