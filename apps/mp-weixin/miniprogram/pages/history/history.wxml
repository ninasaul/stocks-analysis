<view class="page">
  <view class="card">
    <text class="h1">历史与复盘</text>
    <text class="desc">查看已完成的分析记录，便于跟踪与复盘决策过程。</text>
  </view>
  <view wx:if="{{!list.length}}" class="empty">
    <text class="empty-t">暂无记录</text>
    <text class="empty-sub">运行股票预测后，记录会自动保存到这里。</text>
    <button class="empty-btn" bindtap="onGoAnalyze">去股票预测</button>
  </view>
  <view
    wx:for="{{list}}"
    wx:key="id"
    class="row mp-press"
    hover-class="mp-press-hover"
    hover-stay-time="80"
    data-id="{{item.id}}"
    bindtap="onOpenDetail"
  >
    <view class="grow">
      <text class="title">{{item.title}}</text>
      <text class="sub">{{item.sub}}</text>
    </view>
    <text class="badge {{item.badgeClass}}">{{item.actionLabel}}</text>
  </view>
</view>
