{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "strict": true,
    "noImplicitAny": true,
    "noEmit": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "lib": ["ES2020"],
    "types": ["miniprogram-api-typings"]
  },
  "include": ["./miniprogram/**/*.ts", "./typings/**/*.d.ts"],
  "exclude": ["node_modules", "scripts"]
}
