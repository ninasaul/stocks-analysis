{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "TuringFin",
  "version": "0.1.0",
  "identifier": "com.turingfin.desktop",
  "build": {
    "devUrl": "http://localhost:4000/app/analyze",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "TuringFin",
        "width": 1280,
        "height": 820,
        "minWidth": 1024,
        "minHeight": 720
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "Finance",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
